// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum ResourceType {
  video
  document
}

enum Priority {
  low
  medium
  high
}

model Module {
  id          String    @id @default(cuid())
  name        String    @unique
  title       String
  description String
  icon        String

  resources   Resource[]
  todos       TodoItem[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("modules")
}

model Resource {
  id          String       @id @default(cuid())
  moduleId    String
  title       String
  url         String
  type        ResourceType
  description String
  duration    String?
  order       Int          @default(0)

  module      Module       @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("resources")
}

model TodoItem {
  id          String    @id @default(cuid())
  moduleId    String
  title       String
  description String?
  completed   Boolean   @default(false)
  priority    Priority?
  dueDate     DateTime?

  module      Module    @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("todos")
}
